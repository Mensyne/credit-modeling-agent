# 系统配置
SECRET_KEY=your-secret-key-here
DEBUG=True
PORT=8501

# 数据库配置（可选，用于存储项目/用户/操作日志）
DB_TYPE=sqlite
DB_PATH=./data/system.db
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your-password
# DB_NAME=credit_modeling

# 合规配置
SENSITIVE_FEATURES=gender,race,religion,id_card,phone,address
PSI_THRESHOLD=0.2
IV_THRESHOLD=0.02

# 模型部署配置
DEPLOY_PORT=8000
MAX_MODEL_SIZE=1024
